<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Yollab{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🔬</text></svg>">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>

<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_snippet_list') }}">🔬 Yollab</a>
    <div class="navbar-links">
        <a href="{{ path('app_snippet_list') }}">Explorer</a>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_snippet_new') }}">+ Snippet</a>
            <a href="{{ path('app_profile_show', {username: app.user.username}) }}">
                {{ app.user.username }}
                <span class="rep-badge">{{ app.user.reputationScore }}⭐</span>
            </a>
            <a href="{{ path('app_logout') }}">Déconnexion</a>
        {% else %}
            <a href="{{ path('app_login') }}">Connexion</a>
            <a href="{{ path('app_register') }}">Inscription</a>
        {% endif %}
    </div>
</nav>

<main class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

</body>
</html>
