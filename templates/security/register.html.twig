{% extends 'base.html.twig' %}
{% block title %}Inscription — Yollab{% endblock %}

{% block body %}
<div class="auth-card">
    <h1>Créer un compte</h1>

    {{ form_start(form) }}
        {{ form_row(form.username) }}
        {{ form_row(form.email) }}
        {{ form_row(form.plainPassword.first) }}
        {{ form_row(form.plainPassword.second) }}
        <button type="submit" class="btn btn-primary">S'inscrire</button>
    {{ form_end(form) }}

    <p class="auth-footer">Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a></p>
</div>
{% endblock %}
